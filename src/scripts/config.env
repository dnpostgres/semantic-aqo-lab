#!/usr/bin/env bash
# config.env — Source this from every script. Never hardcode paths elsewhere.

# Auto-detect repo root
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"

# PostgreSQL
export PG_VERSION="${PG_VERSION:-15.15}"
export PG_PREFIX="${PG_PREFIX:-/usr/local/pgsql}"
export PG_SRC="$REPO_ROOT/src/postgresql-${PG_VERSION}"
export PG_BIN="$PG_PREFIX/bin"
export PG_LIB="$PG_PREFIX/lib"
export PG_SHARE="$PG_PREFIX/share/extension"
export PG_DATA="$PG_PREFIX/data"
export PG_LOG="$PG_DATA/logfile"
export PSQL="sudo -u postgres $PG_BIN/psql"

# AQO repos
export SAQO_REPO_URL="${SAQO_REPO_URL:-https://github.com/dnpostgres/semantic-aqo-main.git}"
export SAQO_REPO="$REPO_ROOT/src/semantic-aqo-main"
export SAQO_EXT="$SAQO_REPO/extension"
export STD_AQO_REPO_URL="${STD_AQO_REPO_URL:-https://github.com/postgrespro/aqo.git}"
export STD_AQO_REPO="$REPO_ROOT/src/aqo-standard"
export AQO_BRANCH="stable15"
export AQO_CONTRIB_LINK="$PG_SRC/contrib/aqo"

# Benchmark databases
export TPCH_DB="${TPCH_DB:-tpch}"
export TPCDS_DB="${TPCDS_DB:-tpcds}"
export JOB_DB="${JOB_DB:-imdb}"
export STATS_DB="${STATS_DB:-stats}"

# Experiment defaults
export DEFAULT_ITERATIONS="${DEFAULT_ITERATIONS:-15}"
export AQO_JOIN_THRESHOLD="${AQO_JOIN_THRESHOLD:-0}"

# Paths
export EXPERIMENT_DIR="$REPO_ROOT/src/experiment"
export SCRIPTS_DIR="$REPO_ROOT/src/scripts"
export MODELS_DIR="$REPO_ROOT/src/models"
